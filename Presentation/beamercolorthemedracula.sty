% Dracula Theme for Beamer
% https://github.com/dracula/beamer

\mode<presentation>

% Dracula Color Palette
\definecolor{draculabg}{RGB}{40, 42, 54}
\definecolor{draculafg}{RGB}{248, 248, 242}
\definecolor{draculacurrent}{RGB}{68, 71, 90}
\definecolor{draculacomment}{RGB}{98, 114, 164}
\definecolor{draculacyan}{RGB}{139, 233, 253}
\definecolor{draculagreen}{RGB}{80, 250, 123}
\definecolor{draculaorange}{RGB}{255, 184, 108}
\definecolor{draculapink}{RGB}{255, 121, 198}
\definecolor{draculapurple}{RGB}{189, 147, 249}
\definecolor{draculared}{RGB}{255, 85, 85}
\definecolor{draculayellow}{RGB}{241, 250, 140}

% Apply Colors
\setbeamercolor{palette primary}{bg=draculabg, fg=draculafg}
\setbeamercolor{palette secondary}{bg=draculacurrent, fg=draculafg}
\setbeamercolor{palette tertiary}{bg=draculacomment, fg=draculafg}
\setbeamercolor{palette quaternary}{bg=draculabg, fg=draculafg}

\setbeamercolor{structure}{fg=draculapurple}
\setbeamercolor{section in toc}{fg=draculafg}
\setbeamercolor{subsection in toc}{fg=draculafg}

\setbeamercolor{normal text}{fg=draculafg, bg=draculabg}
\setbeamercolor{item}{fg=draculapink}
\setbeamercolor{subitem}{fg=draculacyan}
\setbeamercolor{subsubitem}{fg=draculaorange}

\setbeamercolor{block title}{fg=draculagreen, bg=draculacurrent}
\setbeamercolor{block body}{fg=draculafg, bg=draculacurrent}

\setbeamercolor{title}{fg=draculapurple}
\setbeamercolor{subtitle}{fg=draculafg}
\setbeamercolor{author}{fg=draculafg}
\setbeamercolor{date}{fg=draculacomment}

\setbeamercolor{frametitle}{fg=draculapurple, bg=draculabg}

\mode<all>
